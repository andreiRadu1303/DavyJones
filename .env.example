# Absolute path to your Obsidian vault
# Auto-detected by scripts/setup.sh, or set manually
# VAULT_DIR=/Users/you/MyVault

# Long-lived OAuth token from 'claude setup-token' (valid 1 year, no refresh needed)
# Recommended for always-on systems. Run 'claude setup-token' to generate.
CLAUDE_CODE_OAUTH_TOKEN=

# Fallback: OAuth credentials are extracted from macOS Keychain via scripts/extract_credentials.sh
# and mounted into the agent container. Only needed if CLAUDE_CODE_OAUTH_TOKEN is not set.

# Tuning
POLL_INTERVAL_SECONDS=10
AGENT_TIMEOUT_SECONDS=300
AUTO_COMMIT_DEBOUNCE_SECONDS=5

# MCP integrations (optional — services only start when tokens are set)
GITLAB_TOKEN=
SLACK_BOT_TOKEN=
# Socket Mode app token for interactive Slack bot (enable at api.slack.com/apps → Socket Mode)
SLACK_APP_TOKEN=
# GitHub Personal Access Token — get from GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=
# GitHub Activity Monitoring — polls the repo for changes and triggers vault documentation updates
# Format: owner/repo (e.g., octocat/my-project)
GITHUB_REPO=
GITHUB_POLL_INTERVAL=60

# Google Workspace CLI — gives agents access to Drive, Gmail, Calendar, Sheets, Docs
# Run 'gws auth login' to authenticate with OAuth, then credentials are auto-mounted into containers.
# Enable the APIs you need (Drive, Gmail, Calendar, Sheets) in the Google Cloud Console.
GOOGLE_WORKSPACE_ENABLED=true
GWS_CONFIG_PATH=
